SERVICE_NAME=dub_precedent
ENV_FILE=.env
APP_CONTEXT=dub_precedent
IMAGE_NAME=dub_precedent:latest
CONTAINER_NAME=dub_precedent_app
APP_PORT=8080
HOST_PORT=8080
HEALTHCHECK_PATH=/api/health
BUILD_COMMAND=npm run build:docker
START_COMMAND=npm run start
DEV_COMMAND=npm run dev
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com
REQUIRED_ENV_VARS=POSTGRES_PRISMA_URL POSTGRES_URL_NON_POOLING
ENABLE_DEFAULT_ROUTE_OVERRIDE=true
DEFAULT_GATEWAY=172.18.0.100
POSTGRES_DOCKER_NETWORK=1752417471_internal_network
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
POSTGRES_PRISMA_URL=postgresql://user:password@db-host:5432/app?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgresql://user:password@db-host:5432/app
